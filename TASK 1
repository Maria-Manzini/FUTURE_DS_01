        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.ticker as mtick\n",
        "import numpy as np\n",
        "\n",
        "print(\"Libraries ready ✓\")\n",
        "\n",
        "data = {\n",
        "    'Month': ['Jan','Feb','Mar','Apr','May','Jun',\n",
        "              'Jul','Aug','Sep','Oct','Nov','Dec'],\n",
        "    'Revenue': [42000,38000,51000,47000,55000,62000,\n",
        "                58000,63000,70000,66000,75000,82000],\n",
        "    'Units_Sold': [210,190,255,235,275,310,\n",
        "                   290,315,350,330,375,410],\n",
        "    'Product': ['Laptops','Phones','Tablets','Laptops','Phones',\n",
        "                'Tablets','Laptops','Phones','Tablets','Laptops',\n",
        "                'Phones','Tablets'],\n",
        "    'Region': ['North','South','East','West','North',\n",
        "               'South','East','West','North','South',\n",
        "               'East','West'],\n",
        "    'Category': ['Electronics','Electronics','Electronics',\n",
        "                 'Electronics','Electronics','Electronics',\n",
        "                 'Electronics','Electronics','Electronics',\n",
        "                 'Electronics','Electronics','Electronics']\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "print(\"Dataset created!\")\n",
        "print(df.head())\n",
        "print(f\"\\nTotal Revenue: ${df['Revenue'].sum():,}\")\n",
        "print(f\"Total Units Sold: {df['Units_Sold'].sum():,}\")\n",
        "\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "fig.suptitle('Business Sales Performance Dashboard',\n",
        "             fontsize=16, fontweight='bold', y=1.01)\n",
        "\n",
        "# Chart 1: Revenue trend (line)\n",
        "axes[0,0].plot(df['Month'], df['Revenue'],\n",
        "               color='#185FA5', linewidth=2.5, marker='o', markersize=5)\n",
        "axes[0,0].fill_between(range(len(df)), df['Revenue'],\n",
        "                        alpha=0.1, color='#185FA5')\n",
        "axes[0,0].set_title('Monthly Revenue Trend', fontweight='bold')\n",
        "axes[0,0].set_xlabel('Month')\n",
        "axes[0,0].set_ylabel('Revenue ($)')\n",
        "axes[0,0].yaxis.set_major_formatter(mtick.FuncFormatter(\n",
        "    lambda x, _: f'${x/1000:.0f}K'))\n",
        "axes[0,0].tick_params(axis='x', rotation=45)\n",
        "axes[0,0].grid(axis='y', alpha=0.3)\n",
        "\n",
        "# Chart 2: Revenue by product (bar)\n",
        "product_rev = df.groupby('Product')['Revenue'].sum().sort_values(ascending=False)\n",
        "bars = axes[0,1].bar(product_rev.index, product_rev.values,\n",
        "                      color=['#185FA5','#1D9E75','#D85A30'], width=0.5)\n",
        "axes[0,1].set_title('Revenue by Product', fontweight='bold')\n",
        "axes[0,1].set_ylabel('Revenue ($)')\n",
        "axes[0,1].yaxis.set_major_formatter(mtick.FuncFormatter(\n",
        "    lambda x, _: f'${x/1000:.0f}K'))\n",
        "for bar, val in zip(bars, product_rev.values):\n",
        "    axes[0,1].text(bar.get_x() + bar.get_width()/2,\n",
        "                   bar.get_height() + 1000,\n",
        "                   f'${val/1000:.0f}K', ha='center', fontsize=10)\n",
        "axes[0,1].grid(axis='y', alpha=0.3)\n",
        "\n",
        "# Chart 3: Units sold by region (bar)\n",
        "region_units = df.groupby('Region')['Units_Sold'].sum().sort_values(ascending=False)\n",
        "axes[1,0].bar(region_units.index, region_units.values,\n",
        "              color='#1D9E75', width=0.5)\n",
        "axes[1,0].set_title('Units Sold by Region', fontweight='bold')\n",
        "axes[1,0].set_ylabel('Units Sold')\n",
        "for i, val in enumerate(region_units.values):\n",
        "    axes[1,0].text(i, val + 3, str(val), ha='center', fontsize=10)\n",
        "axes[1,0].grid(axis='y', alpha=0.3)\n",
        "\n",
        "# Chart 4: Monthly units sold (line)\n",
        "axes[1,1].plot(df['Month'], df['Units_Sold'],\n",
        "               color='#D85A30', linewidth=2.5, marker='s', markersize=5)\n",
        "axes[1,1].set_title('Monthly Units Sold Trend', fontweight='bold')\n",
        "axes[1,1].set_xlabel('Month')\n",
        "axes[1,1].set_ylabel('Units Sold')\n",
        "axes[1,1].tick_params(axis='x', rotation=45)\n",
        "axes[1,1].grid(axis='y', alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('sales_dashboard.png', dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "\n",
        "print(\"\\n--- KEY INSIGHTS ---\")\n",
        "print(f\"Best month: {df.loc[df['Revenue'].idxmax(), 'Month']} (${df['Revenue'].max():,})\")\n",
        "print(f\"Top product: {product_rev.index[0]} (${product_rev.iloc[0]:,})\")\n",
        "print(f\"Top region by units: {region_units.index[0]} ({region_units.iloc[0]} units)\")\n",
        "print(f\"Revenue growth Jan-Dec: {((df['Revenue'].iloc[-1]/df['Revenue'].iloc[0])-1)*100:.1f}%\")\n",
        "print(\"\\nChart saved as sales_dashboard.png ✓\")"
      ]
